# Backend production (Node/Express)
PORT=3001

# Postgres (prefer DATABASE_URL in production)
DATABASE_URL=postgresql://user:pass@host:5432/dbname
PGSSLMODE=require

# Comma-separated list of allowed frontend origins, or "*" while testing
CORS_ORIGIN=https://<your-frontend>.vercel.app

# Where uploaded files are stored (use a persistent disk path in production)
UPLOADS_DIR=/var/data/uploads

