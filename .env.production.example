# Frontend production (Vite)
# Option A: Use the local Node/Express backend (recommended if you deployed `backend/`)
VITE_USE_LOCAL_BACKEND=true
VITE_LOCAL_BACKEND_URL=https://<your-api>.onrender.com

# Option B: Use Base44 cloud backend
# VITE_USE_LOCAL_BACKEND=false
# VITE_BASE44_APP_ID=your_app_id
# VITE_BASE44_APP_BASE_URL=https://your-app.base44.app
# VITE_BASE44_FUNCTIONS_VERSION=

# Vite-config-only (not exposed to the browser)
BASE44_LEGACY_SDK_IMPORTS=false

