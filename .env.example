# Frontend (Vite)
# Local dev (npm) prefers .env.local, but Vite also reads .env
VITE_BASE44_APP_ID=your_app_id
VITE_BASE44_APP_BASE_URL=https://your-app.base44.app

# Optional
VITE_BASE44_FUNCTIONS_VERSION=

# Local backend (optional)
VITE_USE_LOCAL_BACKEND=false
VITE_LOCAL_BACKEND_URL=http://localhost:3001

# Vite-config-only (not exposed to the browser)
BASE44_LEGACY_SDK_IMPORTS=false

# Optional (Docker Postgres service "db")
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_USER=atm
POSTGRES_PASSWORD=atm
POSTGRES_DB=atm
POSTGRES_PORT=5432

# Example for a future backend (not used by this frontend)
DATABASE_URL=postgresql://atm:atm@localhost:5432/atm
